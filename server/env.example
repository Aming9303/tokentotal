# TokenTotal payment server
TT_PAY_HOST=127.0.0.1
TT_PAY_PORT=8788
TT_PUBLIC_BASE_URL=https://pay.your-domain.com
TT_PAYMENT_MODE=wechat
TT_PRO_PRICE_FEN=9900
TT_PRO_NAME=TokenTotal Pro
TT_PRO_DESCRIPTION=TokenTotal Pro License

# WeChat Pay API v3 Native payment
WECHAT_APPID=wx_your_appid
WECHAT_MCHID=your_mchid
WECHAT_MERCHANT_SERIAL_NO=your_merchant_api_cert_serial_no
WECHAT_MERCHANT_PRIVATE_KEY_PATH=/secure/path/apiclient_key.pem
WECHAT_API_V3_KEY=your_32_byte_api_v3_key
WECHAT_PAY_PUBLIC_KEY_ID=PUB_KEY_ID_xxx
WECHAT_PAY_PUBLIC_KEY_PATH=/secure/path/wxp_pub.pem

# TokenTotal license signing key.
# The matching public key must be used as TOKENTOTAL_LICENSE_PUBLIC_KEY in the Electron app build/runtime.
TOKENTOTAL_LICENSE_PRIVATE_KEY_PATH=/secure/path/tokentotal_license_private.pem
